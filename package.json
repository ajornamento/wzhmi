{
  "name": "wzhmi",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:editor\" \"npm run dev:mes\"",
    "dev:editor": "npm run dev --workspace=packages/editor",
    "dev:mes": "npm run dev --workspace=packages/mes",
    "dev:server": "npm run dev --workspace=apps/dev-server",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
